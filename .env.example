# Copia a .env (o configura como variables de entorno en tu hosting).
# TODAS son opcionales: sin ninguna, la demo funciona en modo "pre-cocinado".

# Estructuración de informes EN DIRECTO con Claude:
ANTHROPIC_API_KEY=
DEMO_MODEL=claude-sonnet-4-6

# Transcripción de voz (Whisper) EN DIRECTO. Usa UNA de las dos.
# Groq es gratis/barato y rapidísimo (whisper-large-v3-turbo):
GROQ_API_KEY=
# Alternativa OpenAI (whisper-1):
OPENAI_API_KEY=

PORT=5005
